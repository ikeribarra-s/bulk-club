# Copiar a .env y completar. NUNCA commitear el .env real.

# URL del WebSocket del backend en Render (https -> wss)
BACKEND_WS_URL=wss://TU-BACKEND.onrender.com/api/door/ws

# Mismo token que la variable DOOR_AGENT_TOKEN del backend.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
DOOR_AGENT_TOKEN=

# Molinete Hikvision (red local)
MOLINETE_IP=192.168.1.202
# Usuario OPERADOR con permiso solo de control de puerta (crear en la web del .202), NO el admin
MOLINETE_USER=
MOLINETE_PASSWORD=
# 1 = entrada, 2 = salida
MOLINETE_DOOR=1
